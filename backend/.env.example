# Example environment file for the backend.
#
# Copy this file to `.env` in the same folder and fill in real values there:
#
#     cp .env.example .env
#
# `.env` is git-ignored and must NEVER be committed. This file (`.env.example`)
# contains placeholders only and IS committed, so anyone cloning the repo knows
# which variables the project expects.

# --- Django core ---------------------------------------------------------
DEBUG=True
SECRET_KEY=replace-this-in-real-environment
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Database ------------------------------------------------------------
# DB_HOST is the switch between local and cloud:
#   DB_HOST empty  -> Django uses the local SQLite file (leave it empty on your
#                     laptop; nothing else here matters).
#   DB_HOST set    -> Django uses PostgreSQL on Amazon RDS with the values below.
#
# On AWS these are set in the EC2 instance's environment, never in a file that
# is committed. DB_PASSWORD stays EMPTY here — the real password only ever
# exists in AWS and in an untracked local `.env`.
DB_NAME=career_assistant
DB_USER=careeradmin
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
DB_SSLMODE=require

# --- AI provider ---------------------------------------------------------
# AI_PROVIDER=mock  -> no external API call is made; the backend returns a
#                      structured local fallback analysis so the feature can
#                      still be demonstrated offline and at zero cost.
# AI_API_KEY        -> leave EMPTY here. Real keys live only in `.env` on a
#                      developer machine or in the server environment on AWS.
#                      The key is read server-side only and is never sent to
#                      the React frontend.
AI_PROVIDER=mock
AI_API_KEY=
AI_MODEL=mock-local
