# Example environment file for the backend.
#
# Copy this file to `.env` in the same folder and fill in real values there:
#
#     cp .env.example .env
#
# `.env` is git-ignored and must NEVER be committed. This file (`.env.example`)
# contains placeholders only and IS committed, so anyone cloning the repo knows
# which variables the project expects.

# --- Django core ---------------------------------------------------------
DEBUG=True
SECRET_KEY=replace-this-in-real-environment
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Origins allowed to send unsafe requests (must include the scheme). Needed once
# the site is reached through a hostname other than 127.0.0.1, e.g. the EC2
# public DNS name. Empty locally.
CSRF_TRUSTED_ORIGINS=

# Turn on secure cookies, HTTPS redirect, and HSTS. Leave False until TLS is
# actually terminated in front of the app — enabling it over plain HTTP breaks
# logins rather than hardening them.
USE_HTTPS=False

# --- Database ------------------------------------------------------------
# DB_HOST is the switch between local and cloud:
#   DB_HOST empty  -> Django uses the local SQLite file (leave it empty on your
#                     laptop; nothing else here matters).
#   DB_HOST set    -> Django uses PostgreSQL on Amazon RDS with the values below.
#
# On AWS these are set in the EC2 instance's environment, never in a file that
# is committed. DB_PASSWORD stays EMPTY here — the real password only ever
# exists in AWS and in an untracked local `.env`.
DB_NAME=career_assistant
DB_USER=careeradmin
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
DB_SSLMODE=require

# --- AI provider ---------------------------------------------------------
# AI_PROVIDER=mock     -> no external API call is made; the backend returns a
#                         structured local analysis so the feature can still be
#                         demonstrated offline and at zero cost. Keep this
#                         locally unless you are deliberately testing Bedrock.
# AI_PROVIDER=bedrock  -> Amazon Bedrock Runtime via the Converse API.
#
# There is NO AWS key here, and none should ever be added. boto3 uses the EC2
# instance's IAM role on the server, and your configured AWS CLI profile
# locally. If you find yourself wanting to paste an access key into this file,
# the answer is an IAM role, not a key.
AI_PROVIDER=mock

# Bedrock model id (used only when AI_PROVIDER=bedrock). `mock-local` is a
# label, not a real model — it is what the mock reports.
# Planned production model: amazon.nova-micro-v1:0
AI_MODEL=mock-local

# Region whose Bedrock endpoint is called, and where model access must be
# enabled for AI_MODEL.
AWS_BEDROCK_REGION=eu-north-1

# Response length cap (also a cost cap — Bedrock bills per token).
AI_MAX_TOKENS=1200

# Low temperature: factual, conservative, repeatable guidance.
AI_TEMPERATURE=0.2

# True  -> if Bedrock fails, return the local analysis clearly labelled as a
#          fallback (the response never pretends a model produced it).
# False -> if Bedrock fails, return a clean 503 instead.
AI_FALLBACK_TO_MOCK=True

# Unused by mock and bedrock. Reserved for a future key-based provider; leave
# it EMPTY here and in every AWS environment.
AI_API_KEY=
