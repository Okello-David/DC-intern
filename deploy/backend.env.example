# Template for the EC2 environment file: /etc/dc-intern/backend.env
#
# PLACEHOLDERS ONLY. This file is committed; the real file is not, and must
# never be created inside the repository.
#
# On the instance (via Session Manager):
#
#   sudo install -d -m 750 -o root -g ec2-user /etc/dc-intern
#   sudo cp /opt/dc-intern/deploy/backend.env.example /etc/dc-intern/backend.env
#   sudo chown root:ec2-user /etc/dc-intern/backend.env
#   sudo chmod 640 /etc/dc-intern/backend.env
#   sudo nano /etc/dc-intern/backend.env      # fill in the real values
#
# 0640 root:ec2-user means: only root can change it, and only ec2-user (the
# service account) can read it. systemd reads it as root before dropping
# privileges, and the deploy script sources it as ec2-user.
#
# Values come from AWS Systems Manager Parameter Store. Fetch them into this
# file by hand, e.g.:
#
#   aws ssm get-parameter --name /dc-intern/db-password --with-decryption \
#       --query Parameter.Value --output text
#
# Never echo a fetched value into a shell that has command history enabled, and
# never paste one into the repository, a README, or a commit message.

# --- Django core ---------------------------------------------------------
DEBUG=False
# Generate a fresh one on the instance, do not reuse a development key:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=
# The EC2 public DNS name and/or your domain. Comma separated, no scheme.
ALLOWED_HOSTS=
# Where the React frontend is served from. Comma separated, WITH scheme.
CORS_ALLOWED_ORIGINS=
# Same origins, with scheme — needed for the admin site and unsafe requests.
CSRF_TRUSTED_ORIGINS=
# Leave False until TLS is configured (Day 5+). See docs/WEEK4_AI_AND_DEPLOYMENT.md.
USE_HTTPS=False

# --- Database (private Amazon RDS PostgreSQL) ----------------------------
# DB_HOST is the switch: set means PostgreSQL, empty means local SQLite.
DB_NAME=career_assistant
DB_USER=careeradmin
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
DB_SSLMODE=require

# --- AI provider ---------------------------------------------------------
# Keep mock until a provider is approved and a spending cap is in place.
AI_PROVIDER=mock
AI_API_KEY=
AI_MODEL=mock-local
